# TikTok Developer App credentials
# Get these from https://developers.tiktok.com
TIKTOK_CLIENT_KEY=your_client_key_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# The URL TikTok redirects back to after login
# For local development: http://localhost:3000/api/auth/callback
# For production: https://yourdomain.com/api/auth/callback
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# OpenAI API Key for video analysis & content suggestions
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
